// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Prisma 7.x: DB接続URLは prisma.config.ts で管理する。
// schema.prisma には url/directUrl を記述しない。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) required models
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Application models
// ---------------------------------------------------------------------------

/// アプリユーザー（OAuth連携 + 信頼スコア管理）
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// GitHub OAuth の数値ID（信頼スコア計算に利用）
  githubId      String?   @unique
  /// ユーザーの信頼スコア（0.0 〜 1.0）。不正レビュー検知に使用
  trustScore    Float     @default(1.0)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  reviews  Review[]
  flags    Flag[]
}

/// サービスのカテゴリ（例: AI Tools, SaaS, デザインツール）
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  services Service[]
}

/// レビュー対象サービス
model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  website     String?
  /// 集計済み総合スコア（ベイズ平均）。定期バッチで更新
  score       Float    @default(0.0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  reviews    Review[]
}

/// ユーザーが投稿したレビュー
model Review {
  id        String   @id @default(cuid())
  /// 総合評価（1〜5）
  overall   Float
  /// 使いやすさ（1〜5）
  usability Float
  /// コストパフォーマンス（1〜5）
  value     Float
  /// サポート品質（1〜5）
  support   Float
  /// レビュー本文
  body      String   @db.Text
  createdAt DateTime @default(now())

  userId    String
  serviceId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  flags     Flag[]

  /// 同一ユーザーが同一サービスに複数レビューを投稿できないようにする
  @@unique([userId, serviceId])
}

/// 不正・スパムレビューへの通報
model Flag {
  id        String   @id @default(cuid())
  /// 通報理由（例: spam, fake, offensive）
  reason    String
  createdAt DateTime @default(now())

  reviewId String
  userId   String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 同一ユーザーが同一レビューを複数回通報できないようにする
  @@unique([reviewId, userId])
}
