# ============================================================
# Plainrank - Environment Variables Example
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# Auth.js
AUTH_SECRET=                    # Generate with: npx auth secret
AUTH_GITHUB_ID=                 # GitHub OAuth App の Client ID
AUTH_GITHUB_SECRET=             # GitHub OAuth App の Client Secret
AUTH_GOOGLE_ID=                 # Google OAuth の Client ID
AUTH_GOOGLE_SECRET=             # Google OAuth の Client Secret

# Database (Neon / Vercel Postgres)
DATABASE_URL=                   # postgresql://... 形式

# Admin
ADMIN_EMAIL=                    # 管理者のメールアドレス（承認・却下機能に使用）
